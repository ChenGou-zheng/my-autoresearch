{
    "$schema": "https://opencode.ai/config.json",
    "permission": {
        "bash": {
            "*": "allow",
            "rm": "ask",
            "mv": "ask"
        },
        "edit": {
            "*": "allow",
            "myautoresearch/config/program.md": "deny",
            "myautoresearch/config/project.md": "deny",
            "myautoresearch/scripts/**": "deny",
            "myautoresearch/opencode.json": "ask",
            "myautoresearch/config/autoresearch.config.json": "ask"
        }
    }
}
